<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      <%= path === "homepage" ? "Opawnion" : userdata.first_name + " " +
      userdata.last_name%>
    </title>
    <link rel="stylesheet" href="/css/styles.css" />
    <script src="/js/index.js" defer></script>
  </head>
  <body>
    <%- include('./partials/header',) %>
    <% if (path === "homepage") { %>
    <div class="contentBody">
      <% allPostData.forEach(postData => { %>
      <%- include('./partials/postCard', {postData}) %>
      <% }) %>
    </div>
    <% } else if(path === "profilePage"){ %>
    <%- include('./profilePage') %>
    <% } %>
  </body>
</html>
