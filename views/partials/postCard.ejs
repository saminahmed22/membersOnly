<div
  class="postCard <% if (postData.category === 'secret' && userdata.status === 'member') { %> secretPost <% } %>"
>
  <div class="postCardHeader">
    <a class="postCardProfilePictureURL" href="/user/<%= postData.user_id %>">
      <img
        class="postCardProfilePicture"
        src="<%= postData.profile_picture %>"
        alt="Profile picture"
      />
    </a>

    <div class="postData">
      <div class="postCardUsernameContainer">
        <a href="/user/<%= postData.user_id %>">
          <p class="postCardUsername">
            <%= postData.first_name + ' ' + postData.last_name %>
          </p></a
        >
        <% if
        (postData.isadmin) { %>

        <svg
          class="adminIcon"
          alt="Admin icon"
          xmlns="http://www.w3.org/2000/svg"
          height="24px"
          viewBox="0 -960 960 960"
          width="24px"
          fill="#ffffff"
        >
          <title>ADMIN</title>
          <path
            d="M480-80q-139-35-229.5-159.5T160-516v-244l320-120 320 120v244q0 152-90.5 276.5T480-80Zm0-84q104-33 172-132t68-220v-189l-240-90-240 90v189q0 121 68 220t172 132Zm0-316Z"
          />
        </svg>
        <% } %>

        <% if(userdata.status === 'member' &&  postData.status === "member") { %>
        <svg
          class="secretMemberIcon"
          width="800px"
          height="800px"
          viewBox="0 0 512 512"
          xmlns="http://www.w3.org/2000/svg"
        >
          <title>Member of the council</title>
          <path
            fill="var(--ci-primary-color, #000000)"
            d="M374.762,186.866h0a54.1,54.1,0,0,0-51.305-36.706H280V21.552l-18.263,2.609c-41.429,5.918-73.7,26.912-95.907,62.4-16.011,25.581-23.454,53.8-26.908,74.906-23.847,18.348-44.593,43.611-61.738,75.2-14.449,26.618-26.41,57.816-35.552,92.729-15.447,58.99-17.538,107.921-17.619,109.975L24.005,496H56V440.364c.4-8.231,10.476-188.35,107.032-256.936l5.66-4.021.93-6.881C174.437,136.9,191.077,78.058,248,59.971V182.16h75.457a22.12,22.12,0,0,1,21,14.974h0c12.757,37.656,34.677,84.777,68.839,106.921l-10.274,38.528a62.688,62.688,0,0,1-62.54,46.87c-28.668-.86-58.506,2.88-88.689,11.111L240,403.779V496h32V428.468a265.353,265.353,0,0,1,67.52-7.03,94.97,94.97,0,0,0,94.418-70.61l17.088-64.081L438.3,281.293C414.5,271.093,391.936,237.558,374.762,186.866Z"
            class="ci-primary"
          />
        </svg>
        <% } %>
      </div>

      <p class="postCardDate"><%= postData.created_at%></p>
    </div>

    <%if(userdata.isadmin || userdata.user_id === postData.user_id){%>
    <button class="deletePostBtn" data-postId="<%= postData.post_id %>">
      <svg
        class="deleteBtnIcon"
        xmlns="http://www.w3.org/2000/svg"
        height="24px"
        viewBox="0 -960 960 960"
        width="24px"
        fill="#ffffff"
      >
        <path
          d="M280-120q-33 0-56.5-23.5T200-200v-520h-40v-80h200v-40h240v40h200v80h-40v520q0 33-23.5 56.5T680-120H280Zm400-600H280v520h400v-520ZM360-280h80v-360h-80v360Zm160 0h80v-360h-80v360ZM280-720v520-520Z"
        />
      </svg>
    </button>
    <%}%>
  </div>
  <div class="postContent">
    <p class="postTitle"><%= postData.post_title%></p>
    <p class="postDesc"><%= postData.post_description%></p>
  </div>
</div>
