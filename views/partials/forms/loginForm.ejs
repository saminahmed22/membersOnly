<div class="loginFormContainer formContainer">
  <p class="formTitle">Login</p>
  <% if (passportErrorMessages.length > 0) { %>
  <div class="formErrorMessageContainer">
    <p class="formErrorMessage"><%= passportErrorMessages %></p>
  </div>
  <% } %>
  <form action="/login" method="POST">
    <div class="inputContainer">
      <label for="username">Username:</label>
      <input
        type="text"
        name="username"
        id="username"
        value="<%= values.username %>"
      />

      <%- include('./formErrorMessage', {target: "username"}) %>
    </div>

    <div class="inputContainer">
      <label for="password">Password:</label>
      <input
        type="password"
        name="password"
        id="password"
        value="<%= values.password %>"
      />

      <%- include('./formErrorMessage', {target: "password"}) %>
    </div>

    <button type="submit">Login</button>
  </form>
  <p class="formActText">
    No account? <a href="/register">Register for free!</a>
  </p>
</div>
